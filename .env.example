# Salin file ini menjadi .env.local dan isi dengan nilai dari dashboard Supabase Anda
# Jangan pernah commit file .env.local ke git

# URL project Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable key Supabase (Settings > API > Project API keys > publishable)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# URL situs (digunakan untuk sitemap dan Open Graph)
NEXT_PUBLIC_SITE_URL=https://alucurv.vercel.app
